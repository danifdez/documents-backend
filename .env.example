# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=documents
POSTGRES_USER=postgres
POSTGRES_PASSWORD=example

# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173
BODY_LIMIT=50mb

# File Storage
DOCUMENTS_STORAGE_DIR=../documents

# Authentication (set AUTH_ENABLED=true for multi-user mode)
AUTH_ENABLED=false
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Offline support (set OFFLINE_ENABLED=true to allow clients to cache content)
OFFLINE_ENABLED=false
OFFLINE_FILE_SIZE_LIMIT=10485760

# Feature Flags (set to false to disable a feature)
FEATURE_ENTITIES=true
FEATURE_AUTHORS=true
FEATURE_CANVAS=true
FEATURE_DATASETS=true
FEATURE_NOTES=true
FEATURE_CALENDAR=true
FEATURE_TIMELINES=true
FEATURE_KNOWLEDGE_BASE=true
FEATURE_BIBLIOGRAPHY=true
FEATURE_TASKS=true
FEATURE_RAG=true
FEATURE_RELATIONSHIPS=true
FEATURE_DATA_SOURCES=true

# Data Sources (encryption key for API credentials stored in database)
DATASOURCE_ENCRYPTION_KEY=change-me-in-production-32-chars
