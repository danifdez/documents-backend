#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$SCRIPT_DIR"

# ‚îÄ‚îÄ Colors ‚îÄ‚îÄ
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'

info()  { printf "${CYAN}[INFO]${NC}  %s\n" "$*"; }
ok()    { printf "${GREEN}[OK]${NC}    %s\n" "$*"; }
warn()  { printf "${YELLOW}[WARN]${NC}  %s\n" "$*"; }
fail()  { printf "${RED}[ERROR]${NC} %s\n" "$*" >&2; exit 1; }

ask() {
  local prompt="$1" default="$2"
  printf "  ${BOLD}%s${NC} ${DIM}[%s]${NC}: " "$prompt" "$default"
  read -r REPLY
  REPLY="${REPLY:-$default}"
}

# ‚îÄ‚îÄ Load root .env defaults ‚îÄ‚îÄ
if [ -f "$ROOT_DIR/.env" ]; then
  set -a
  # shellcheck disable=SC1091
  source "$ROOT_DIR/.env"
  set +a
fi

# ‚îÄ‚îÄ Check Node.js ‚îÄ‚îÄ
command -v node >/dev/null 2>&1 || fail "Node.js is not installed."
command -v npm  >/dev/null 2>&1 || fail "npm is not installed."

NODE_VERSION=$(node -v)
info "Node.js $NODE_VERSION detected"

# ‚îÄ‚îÄ Configure .env ‚îÄ‚îÄ
if [ -f ".env" ]; then
  ok ".env already exists (skipping)"
else
  echo ""
  printf "${BOLD}${CYAN}‚îÄ‚îÄ Backend environment configuration ‚îÄ‚îÄ${NC}\n"
  printf "${DIM}  Press Enter to accept the default value shown in brackets.${NC}\n"
  echo ""

  ask "PostgreSQL host" "${POSTGRES_HOST:-localhost}";       PG_HOST="$REPLY"
  ask "PostgreSQL port" "${POSTGRES_PORT:-5432}";            PG_PORT="$REPLY"
  ask "PostgreSQL database" "${POSTGRES_DB:-documents}";     PG_DB="$REPLY"
  ask "PostgreSQL user" "${POSTGRES_USER:-postgres}";        PG_USER="$REPLY"
  ask "PostgreSQL password" "${POSTGRES_PASSWORD:-example}"; PG_PASS="$REPLY"
  ask "Backend server port" "3000";                          PORT="$REPLY"
  ask "CORS origin" "http://localhost:5173";                 CORS="$REPLY"
  ask "Body size limit" "50mb";                              BODY="$REPLY"
  ask "Documents storage directory" "../documents";          STORAGE="$REPLY"
  ask "Enable authentication (true/false)" "false";          AUTH="$REPLY"
  ask "JWT secret" "change-me-in-production";                JWT="$REPLY"
  ask "JWT access token expiry" "15m";                       JWT_ACCESS="$REPLY"
  ask "JWT refresh token expiry" "7d";                       JWT_REFRESH="$REPLY"
  ask "Default admin username" "admin";                      ADMIN_USER="$REPLY"
  ask "Default admin password" "admin";                      ADMIN_PASS="$REPLY"
  ask "Enable offline support (true/false)" "false";         OFFLINE="$REPLY"
  ask "Offline file size limit (bytes)" "10485760";          OFFLINE_LIMIT="$REPLY"

  echo ""
  printf "${BOLD}${CYAN}‚îÄ‚îÄ Feature Flags ‚îÄ‚îÄ${NC}\n"
  printf "${DIM}  Enable or disable optional features. All enabled by default.${NC}\n"
  echo ""
  ask "Enable Entities (true/false)" "true";                 FEAT_ENTITIES="$REPLY"
  ask "Enable Authors (true/false)" "true";                  FEAT_AUTHORS="$REPLY"
  ask "Enable Canvas (true/false)" "true";                   FEAT_CANVAS="$REPLY"
  ask "Enable Datasets (true/false)" "true";                 FEAT_DATASETS="$REPLY"
  ask "Enable Notes (true/false)" "true";                    FEAT_NOTES="$REPLY"
  ask "Enable Calendar (true/false)" "true";                 FEAT_CALENDAR="$REPLY"
  ask "Enable Timelines (true/false)" "true";                FEAT_TIMELINES="$REPLY"
  ask "Enable Knowledge Base (true/false)" "true";           FEAT_KB="$REPLY"
  ask "Enable Bibliography (true/false)" "true";             FEAT_BIB="$REPLY"
  ask "Enable Tasks (true/false)" "true";                    FEAT_TASKS="$REPLY"
  ask "Enable AI / RAG (true/false)" "true";                 FEAT_RAG="$REPLY"
  ask "Enable Relationships (true/false)" "true";            FEAT_RELATIONSHIPS="$REPLY"

  cat > ".env" <<EOF
# Database
POSTGRES_HOST=$PG_HOST
POSTGRES_PORT=$PG_PORT
POSTGRES_DB=$PG_DB
POSTGRES_USER=$PG_USER
POSTGRES_PASSWORD=$PG_PASS

# Server
PORT=$PORT
CORS_ORIGIN=$CORS
BODY_LIMIT=$BODY

# File Storage
DOCUMENTS_STORAGE_DIR=$STORAGE

# Authentication (set AUTH_ENABLED=true for multi-user mode)
AUTH_ENABLED=$AUTH
JWT_SECRET=$JWT
JWT_ACCESS_EXPIRY=$JWT_ACCESS
JWT_REFRESH_EXPIRY=$JWT_REFRESH
ADMIN_USERNAME=$ADMIN_USER
ADMIN_PASSWORD=$ADMIN_PASS

# Offline support (set OFFLINE_ENABLED=true to allow clients to cache content)
OFFLINE_ENABLED=$OFFLINE
OFFLINE_FILE_SIZE_LIMIT=$OFFLINE_LIMIT

# Feature Flags (set to false to disable a feature)
FEATURE_ENTITIES=$FEAT_ENTITIES
FEATURE_AUTHORS=$FEAT_AUTHORS
FEATURE_CANVAS=$FEAT_CANVAS
FEATURE_DATASETS=$FEAT_DATASETS
FEATURE_NOTES=$FEAT_NOTES
FEATURE_CALENDAR=$FEAT_CALENDAR
FEATURE_TIMELINES=$FEAT_TIMELINES
FEATURE_KNOWLEDGE_BASE=$FEAT_KB
FEATURE_BIBLIOGRAPHY=$FEAT_BIB
FEATURE_TASKS=$FEAT_TASKS
FEATURE_RAG=$FEAT_RAG
FEATURE_RELATIONSHIPS=$FEAT_RELATIONSHIPS
EOF
  ok "Created .env"
fi

# ‚îÄ‚îÄ Install dependencies ‚îÄ‚îÄ
info "Installing npm dependencies..."
npm install
ok "Dependencies installed"

# ‚îÄ‚îÄ Run base migrations (requires running PostgreSQL) ‚îÄ‚îÄ
if [ "${SKIP_MIGRATIONS:-}" = "1" ]; then
  info "Skipping migrations (SKIP_MIGRATIONS=1)"
else
  info "Running base database migrations..."
  npm run migration:run
  ok "Base migrations complete"
fi

# ‚îÄ‚îÄ Install enabled features ‚îÄ‚îÄ
info "Installing enabled features..."
npm run feature:install
ok "Feature installation complete"

echo ""
printf "${GREEN}============================================${NC}\n"
printf "${GREEN}  Backend installation complete!${NC}\n"
printf "${GREEN}============================================${NC}\n"
echo ""
echo "  Start (dev):   npm run start:dev"
echo "  Start (prod):  npm run build && npm run start:prod"
echo ""
